# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/automart
AUTH_DB_URL=postgresql://postgres:postgres@localhost:5432/automart_auth
PRODUCT_DB_URL=postgresql://postgres:postgres@localhost:5432/automart_products
ORDER_DB_URL=postgresql://postgres:postgres@localhost:5432/automart_orders
INVENTORY_DB_URL=postgresql://postgres:postgres@localhost:5432/automart_inventory

# Auth
JWT_SECRET=change-me-to-a-random-secret
JWT_EXPIRES_IN=7d

# Redis (for BullMQ / pub-sub)
REDIS_URL=redis://localhost:6379

# Services
PORT=3000
API_GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
PRODUCT_SERVICE_PORT=3002
SEARCH_SERVICE_PORT=3003
ORDER_SERVICE_PORT=3004
INVENTORY_SERVICE_PORT=3005
NOTIFICATION_SERVICE_PORT=3006
MCP_SERVER_PORT=3007

# Cloudinary (free tier)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Resend (email - free tier)
RESEND_API_KEY=

# CLIP model path (local)
CLIP_MODEL_PATH=./models/clip

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:3000
