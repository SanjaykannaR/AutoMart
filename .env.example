# ════════════════════════════════════════════════════════════════════════════════
# AutoMart — Environment Variables
# ════════════════════════════════════════════════════════════════════════════════
# Copy to .env and fill in values. Docker Compose loads .env automatically.
# For Docker: use .env.docker (Redis uses service name "redis" as hostname).
# For local dev: use Redis at localhost:6379.
# ════════════════════════════════════════════════════════════════════════════════

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-secret
JWT_EXPIRES_IN=7d

# ── Google OAuth ─────────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local dev:  redis://localhost:6379
# Docker:     redis://redis:6379
REDIS_URL=redis://localhost:6379

# ── Service Ports ─────────────────────────────────────────────────────────────
API_GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
PRODUCT_SERVICE_PORT=3002
SEARCH_SERVICE_PORT=3003
ORDER_SERVICE_PORT=3004
INVENTORY_SERVICE_PORT=3005
NOTIFICATION_SERVICE_PORT=3006
MCP_SERVER_PORT=3007

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000

# ── Email (Resend free tier) ─────────────────────────────────────────────────
RESEND_API_KEY=
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend

# ── Cloudinary (image uploads — optional) ────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── CLIP Model (local image search — optional) ──────────────────────────────
CLIP_MODEL_PATH=./models/clip
