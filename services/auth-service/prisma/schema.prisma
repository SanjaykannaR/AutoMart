generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/auth"
}

datasource db {
  provider = "sqlite"
  url      = "file:./automart_auth.db"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("individual") // mechanic | individual | shop
  phone     String?
  address   String?
  sessions  Session[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
