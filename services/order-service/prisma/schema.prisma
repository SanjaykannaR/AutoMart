generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/order"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = "file:/data/automart_orders.db"
}

model Order {
  id               String   @id @default(cuid())
  userId           String
  items            String
  total            Float
  status           String   @default("pending") // pending | confirmed | picked | shipped | delivered | cancelled
  address          String
  phone            String
  note             String?
  estimatedDelivery DateTime?
  deliveredAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
