generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/product"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = "file:/data/automart_products.db"
}

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  icon     String?
  products Product[]
}

model Product {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique
  description       String
  brand             String
  price             Float
  imageUrl          String?
  categoryId        String
  category          Category @relation(fields: [categoryId], references: [id])
  vehicleType       String   @default("both") // car | bike | both
  compatibleVehicles String  @default("[]")
  specifications    String?
  stock             Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
