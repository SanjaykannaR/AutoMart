# ── AutoMart Docker Environment ───────────────────────────────────────────────
# Copy this to .env.docker and fill in your real values.
# .env.docker is gitignored — never commit real secrets.
# Service-to-service communication uses Docker DNS names (e.g. redis:6379).

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-secret
JWT_EXPIRES_IN=7d

# ── Google OAuth ─────────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=change-me-to-a-random-redis-password

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for browser requests
CORS_ORIGINS=http://localhost:3080

# ── Service Ports (internal) ─────────────────────────────────────────────────
API_GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
PRODUCT_SERVICE_PORT=3002
SEARCH_SERVICE_PORT=3003
ORDER_SERVICE_PORT=3004
INVENTORY_SERVICE_PORT=3005
NOTIFICATION_SERVICE_PORT=3006
MCP_SERVER_PORT=3007

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000

# ── Email (mock in Docker unless configured) ──────────────────────────────────
RESEND_API_KEY=
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend

# ── Stripe (Test Mode) ────────────────────────────────────────────────────────
# Dashboard: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Supabase ─────────────────────────────────────────────────────────────────
# Dashboard: https://supabase.com/dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SECRET_KEY=your-secret-key

# Frontend (NEXT_PUBLIC_ = exposed to browser — anon key is safe to share)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
